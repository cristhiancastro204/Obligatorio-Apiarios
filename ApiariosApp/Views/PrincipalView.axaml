<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ApiariosApp.Views"
             x:Class="ApiariosApp.Views.PrincipalView"
             x:DataType="local:PrincipalView"
             Background="#F9FAFB"
             FontFamily="Inter, Arial, sans-serif">

  <ScrollViewer Margin="30,20,30,20">
    <StackPanel Spacing="30">
      
      <!-- Welcome Header & Top Buttons -->
      <Grid ColumnDefinitions="*, Auto">
        <StackPanel Grid.Column="0" VerticalAlignment="Center">
          <TextBlock Text="Buen día, Apicultor" FontSize="28" FontWeight="Bold" Foreground="#1A202C"/>
          <TextBlock Text="Resumen de operaciones para el día de hoy." FontSize="14" Foreground="#718096" Margin="0,5,0,0"/>
        </StackPanel>
        
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="15" VerticalAlignment="Center">
          <Button Background="#E6F4EA" CornerRadius="4" Padding="15,10" BorderThickness="0">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <PathIcon Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z" Width="16" Height="16" Foreground="#276749"/>
              <TextBlock Text="Registrar Cosecha" FontWeight="SemiBold" Foreground="#276749" FontSize="13"/>
            </StackPanel>
          </Button>
          <Button Background="#F6B100" CornerRadius="4" Padding="15,10" BorderThickness="0">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="+" FontWeight="Bold" Foreground="#5C4033" FontSize="16"/>
              <TextBlock Text="Nueva Inspección" FontWeight="SemiBold" Foreground="#5C4033" FontSize="13"/>
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>

      <!-- Stats Cards Row -->
      <Grid ColumnDefinitions="*, 20, *, 20, 2*" MinHeight="140">
        
        <!-- Card 1 -->
        <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="20" BoxShadow="0 2 5 0 #05000000" BorderBrush="#F0F2F5" BorderThickness="1">
          <StackPanel>
            <Grid ColumnDefinitions="*, Auto">
              <Border Grid.Column="0" Background="#FEF3C7" CornerRadius="4" Width="40" Height="40" HorizontalAlignment="Left">
                <PathIcon Data="M14 6l-3.75 5 2.85 3.8-1.6 1.2C9.81 13.75 7 10 7 10l-6 8h22L14 6z" Width="20" Height="20" Foreground="#D97706"/>
              </Border>
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Top">
                <PathIcon Data="M16 6l2.29 2.29-4.88 4.88-4-4L2 16.59 3.41 18l6-6 4 4 6.3-6.29L22 12V6z" Width="14" Height="14" Foreground="#059669"/>
                <TextBlock Text="+2" FontSize="14" FontWeight="Bold" Foreground="#059669"/>
              </StackPanel>
            </Grid>
            <TextBlock Text="TOTAL APIARIOS" FontSize="11" FontWeight="Bold" Foreground="#4A5568" Margin="0,20,0,5"/>
            <TextBlock Text="14" FontSize="36" FontWeight="Bold" Foreground="#1A202C"/>
          </StackPanel>
        </Border>

        <!-- Card 2 -->
        <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="20" BoxShadow="0 2 5 0 #05000000" BorderBrush="#F0F2F5" BorderThickness="1">
          <StackPanel>
            <Grid ColumnDefinitions="*, Auto">
              <Border Grid.Column="0" Background="#FEE2E2" CornerRadius="4" Width="40" Height="40" HorizontalAlignment="Left">
                <PathIcon Data="M21 16.5c0 .38-.21.71-.53.88l-7.9 4.44c-.16.12-.36.18-.57.18-.21 0-.41-.06-.57-.18l-7.9-4.44A.991.991 0 0 1 3 16.5v-9c0-.38.21-.71.53-.88l7.9-4.44c.16-.12.36-.18.57-.18.21 0 .41.06.57.18l7.9 4.44c.32.17.53.5.53.88v9zM12 4.15L6.04 7.5 12 10.85l5.96-3.35L12 4.15z" Width="20" Height="20" Foreground="#DC2626"/>
              </Border>
              <TextBlock Grid.Column="1" Text="Estable" FontSize="14" FontWeight="Bold" Foreground="#4A5568" VerticalAlignment="Top"/>
            </Grid>
            <TextBlock Text="TOTAL COLMENAS" FontSize="11" FontWeight="Bold" Foreground="#4A5568" Margin="0,20,0,5"/>
            <TextBlock Text="342" FontSize="36" FontWeight="Bold" Foreground="#1A202C"/>
          </StackPanel>
        </Border>

        <!-- Card 3: Weather/Season -->
        <Border Grid.Column="4" Background="#FAFAF9" CornerRadius="8" Padding="24" BoxShadow="0 2 5 0 #05000000" BorderBrush="#E2E8F0" BorderThickness="1" ClipToBounds="True">
          <Grid>
            <!-- Background Decoration -->
            <Ellipse Width="150" Height="150" Fill="#F0F2F5" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-50,-50,0" Opacity="0.5"/>
            <Ellipse Width="80" Height="80" Fill="#F0F2F5" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-20,-30" Opacity="0.5"/>
            
            <!-- Content -->
            <Grid ColumnDefinitions="*, Auto">
              <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="CLIMA - RIVERA" FontSize="11" FontWeight="Bold" Foreground="#4A5568" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                  <TextBlock Text="{Binding WeatherTemp}" FontSize="32" FontWeight="Bold" Foreground="#1A202C"/>
                  <PathIcon Data="M12 4V1L8 5l4 4V6c3.31 0 6 2.69 6 6 0 1.01-.25 1.97-.7 2.8l1.46 1.46C19.54 15.03 20 13.57 20 12c0-4.42-3.58-8-8-8zm0 14c-3.31 0-6-2.69-6-6 0-1.01.25-1.97.7-2.8L5.24 7.74C4.46 8.97 4 10.43 4 12c0 4.42 3.58 8 8 8v3l4-4-4-4v3z" Width="24" Height="24" Foreground="#D97706" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="{Binding WeatherDesc}" FontSize="13" Foreground="#4A5568" Margin="0,5,0,15"/>
                
                <StackPanel Orientation="Horizontal" Spacing="24">
                  <StackPanel>
                    <TextBlock Text="Humedad" FontSize="11" Foreground="#718096"/>
                    <TextBlock Text="{Binding WeatherHumidity}" FontSize="13" FontWeight="SemiBold" Foreground="#1A202C"/>
                  </StackPanel>
                  <StackPanel>
                    <TextBlock Text="Viento" FontSize="11" Foreground="#718096"/>
                    <TextBlock Text="{Binding WeatherWind}" FontSize="13" FontWeight="SemiBold" Foreground="#1A202C"/>
                  </StackPanel>
                </StackPanel>
              </StackPanel>

              <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                <Border Background="#E6F4EA" CornerRadius="16" Padding="12,6" HorizontalAlignment="Right" Margin="0,0,0,10">
                  <TextBlock Text="Condiciones Óptimas" FontSize="12" FontWeight="Bold" Foreground="#276749"/>
                </Border>
                <TextBlock Text="{Binding SeasonMessage}" FontSize="12" Foreground="#4A5568" TextWrapping="Wrap" MaxWidth="160" TextAlignment="Right" FontWeight="SemiBold"/>
              </StackPanel>
            </Grid>
          </Grid>
        </Border>
      </Grid>

      <!-- Bottom Section Row -->
      <Grid ColumnDefinitions="1.5*, 30, 1*">
        
        <!-- Alertas Sanitarias -->
        <Border Grid.Column="0" Background="#FEF2F2" CornerRadius="8" Padding="24" BorderBrush="#FCA5A5" BorderThickness="1">
          <StackPanel>
            <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,20">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <PathIcon Data="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z" Width="20" Height="20" Foreground="#DC2626"/>
                <TextBlock Text="Alertas Sanitarias" FontSize="18" FontWeight="Bold" Foreground="#991B1B"/>
              </StackPanel>
              <Border Grid.Column="1" Background="#DC2626" CornerRadius="12" Padding="12,4">
                <TextBlock Text="{Binding AlertasCriticasCount, StringFormat='\{0\} Críticas'}" FontSize="12" FontWeight="Bold" Foreground="White"/>
              </Border>
            </Grid>

            <ItemsControl ItemsSource="{Binding AlertasList}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="local:AlertaItem">
                  <Border Background="White" CornerRadius="6" Padding="16" Margin="0,0,0,10" BoxShadow="0 1 3 0 #10000000">
                    <Grid ColumnDefinitions="Auto, *, Auto, Auto">
                      <Border Grid.Column="0" Background="#FEE2E2" CornerRadius="4" Width="36" Height="36" Margin="0,0,16,0">
                        <PathIcon Data="M20 6h-2.18c.11-.31.18-.65.18-1 0-1.66-1.34-3-3-3-1.05 0-1.96.54-2.5 1.35l-.5.67-.5-.68C10.96 2.54 10.05 2 9 2 7.34 2 6 3.34 6 5c0 .35.07.69.18 1H4c-1.11 0-1.99.89-1.99 2L2 19c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V8c0-1.11-.89-2-2-2zm-5-2c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zM9 4c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm11 15H4v-2h16v2zm0-5H4V8h5.08L7 10.83 8.62 12 11 8.76l1-1.36 1 1.36L15.38 12 17 10.83 14.92 8H20v6z" Width="18" Height="18" Foreground="#DC2626"/>
                      </Border>
                      <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Titulo}" FontSize="15" FontWeight="Bold" Foreground="#1A202C"/>
                        <TextBlock Text="{Binding Subtitulo}" FontSize="13" Foreground="#4A5568"/>
                      </StackPanel>
                      <TextBlock Grid.Column="2" Text="{Binding Tiempo}" FontSize="12" FontWeight="Bold" Foreground="#DC2626" VerticalAlignment="Center" Margin="0,0,16,0" TextAlignment="Right"/>
                      <PathIcon Grid.Column="3" Data="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z" Width="18" Height="18" Foreground="#A0AEC0" VerticalAlignment="Center"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <!-- Tareas del Día -->
        <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="24" BoxShadow="0 2 5 0 #05000000" BorderBrush="#E2E8F0" BorderThickness="1">
          <Grid RowDefinitions="Auto, *, Auto">
            <TextBlock Grid.Row="0" Text="Tareas del Día" FontSize="18" FontWeight="Bold" Foreground="#1A202C" Margin="0,0,0,20"/>
            
            <ItemsControl Grid.Row="1" ItemsSource="{Binding TareasList}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="local:TareaItem">
                  <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <CheckBox IsChecked="{Binding Completada}" Margin="0,0,12,0"/>
                    <StackPanel>
                      <TextBlock Text="{Binding Titulo}" FontSize="14" Foreground="#1A202C" TextWrapping="Wrap"/>
                      <TextBlock Text="{Binding Detalles}" FontSize="12" Foreground="{Binding DetallesColor}" FontWeight="SemiBold"/>
                    </StackPanel>
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button Grid.Row="2" Background="Transparent" Foreground="#9C6026" Content="Ver todas las tareas" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center" Margin="0,20,0,0"/>
          </Grid>
        </Border>

      </Grid>
    </StackPanel>
  </ScrollViewer>
</UserControl>
