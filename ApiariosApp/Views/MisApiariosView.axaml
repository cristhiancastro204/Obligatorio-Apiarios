<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ApiariosApp.Views"
             x:Class="ApiariosApp.Views.MisApiariosView"
             x:DataType="local:MisApiariosView"
             Background="#F9FAFB"
             FontFamily="Inter, Arial, sans-serif">

  <ScrollViewer Margin="30,20,30,20">
    <StackPanel Spacing="30">
      
      <!-- Top Header Area -->
      <Grid ColumnDefinitions="*, Auto">
        <StackPanel>
          <!-- Breadcrumb -->
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Mis Apiarios" FontSize="13" Foreground="#718096" FontWeight="SemiBold"/>
            <TextBlock Text=">" FontSize="13" Foreground="#A0AEC0"/>
            <TextBlock Text="Zona Norte" FontSize="13" Foreground="#1A202C" FontWeight="Bold"/>
          </StackPanel>
          
          <!-- Title & Badge -->
          <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,10,0,6">
            <TextBlock Text="Apiario: Los Girasoles" FontSize="32" FontWeight="Bold" Foreground="#1A202C"/>
            <Border Background="#DCFCE7" CornerRadius="6" Padding="10,4" VerticalAlignment="Center">
              <TextBlock Text="Activo" FontSize="12" FontWeight="Bold" Foreground="#166534"/>
            </Border>
          </StackPanel>

          <!-- Location Info -->
          <StackPanel Orientation="Horizontal" Spacing="8">
            <PathIcon Data="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" Width="14" Height="14" Foreground="#718096"/>
            <TextBlock Text="Lat: -34.6037, Long: -58.3816 • Última visita: Hace 4 días" FontSize="13" Foreground="#718096"/>
          </StackPanel>
        </StackPanel>
        
        <!-- Action Button -->
        <Button Grid.Column="1" Background="#8B5A2B" CornerRadius="6" Padding="20,12" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <PathIcon Data="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM7 10h5v5H7z" Width="16" Height="16" Foreground="White"/>
            <TextBlock Text="Planificar Visita" FontWeight="Bold" Foreground="White" FontSize="14"/>
          </StackPanel>
        </Button>
      </Grid>

      <!-- Stats Cards Row -->
      <Grid ColumnDefinitions="*, 20, *, 20, *, 20, *">
        
        <!-- Card 1: Total Colmenas -->
        <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="20" BoxShadow="0 2 5 0 #05000000" BorderBrush="#F0F2F5" BorderThickness="1">
          <StackPanel>
            <PathIcon Data="M20.5 15.1L12 20 3.5 15.1v-6.2L12 4l8.5 4.9v6.2z M12 6.3L6.5 9.5l5.5 3.2 5.5-3.2L12 6.3z" Width="20" Height="20" Foreground="#D97706" HorizontalAlignment="Left"/>
            <TextBlock Text="Total Colmenas" FontSize="12" FontWeight="Bold" Foreground="#4A5568" Margin="0,12,0,5"/>
            <TextBlock Text="48" FontSize="36" FontWeight="Bold" Foreground="#1A202C"/>
          </StackPanel>
        </Border>

        <!-- Card 2: Saludables -->
        <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="20" BoxShadow="0 2 5 0 #05000000" BorderBrush="#F0F2F5" BorderThickness="1">
          <StackPanel>
            <Grid ColumnDefinitions="*, Auto">
              <PathIcon Grid.Column="0" Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" Width="20" Height="20" Foreground="#059669" HorizontalAlignment="Left"/>
              <Border Grid.Column="1" Background="#DCFCE7" CornerRadius="4" Padding="8,2">
                <TextBlock Text="Óptimo" FontSize="11" FontWeight="Bold" Foreground="#166534"/>
              </Border>
            </Grid>
            <TextBlock Text="Saludables" FontSize="12" FontWeight="Bold" Foreground="#4A5568" Margin="0,12,0,5"/>
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom">
              <TextBlock Text="42" FontSize="36" FontWeight="Bold" Foreground="#1A202C"/>
              <TextBlock Text="87%" FontSize="13" FontWeight="Bold" Foreground="#059669" VerticalAlignment="Bottom" Margin="0,0,0,6"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Card 3: En Alerta -->
        <Border Grid.Column="4" Background="White" CornerRadius="8" Padding="20" BoxShadow="0 2 5 0 #05000000" BorderBrush="#DC2626" BorderThickness="4,0,0,0">
          <StackPanel>
            <Grid ColumnDefinitions="*, Auto">
              <PathIcon Grid.Column="0" Data="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z" Width="20" Height="20" Foreground="#DC2626" HorizontalAlignment="Left"/>
              <Border Grid.Column="1" Background="#FEE2E2" CornerRadius="4" Padding="8,2">
                <TextBlock Text="Revisión" FontSize="11" FontWeight="Bold" Foreground="#991B1B"/>
              </Border>
            </Grid>
            <TextBlock Text="En Alerta" FontSize="12" FontWeight="Bold" Foreground="#4A5568" Margin="0,12,0,5"/>
            <TextBlock Text="6" FontSize="36" FontWeight="Bold" Foreground="#1A202C"/>
          </StackPanel>
        </Border>

        <!-- Card 4: Producción -->
        <Border Grid.Column="6" Background="White" CornerRadius="8" Padding="20" BoxShadow="0 2 5 0 #05000000" BorderBrush="#F0F2F5" BorderThickness="1">
          <StackPanel>
            <PathIcon Data="M12 2c0 0-7 5.61-7 11.23C5 17.13 8.13 20 12 20s7-2.87 7-6.77C19 7.61 12 2 12 2zm0 16c-2.76 0-5-2.24-5-5 0-4.06 4.38-8.52 5-9.15.62.63 5 5.09 5 9.15 0 2.76-2.24 5-5 5z" Width="20" Height="20" Foreground="#718096" HorizontalAlignment="Left"/>
            <TextBlock Text="Est. Producción (kg)" FontSize="12" FontWeight="Bold" Foreground="#4A5568" Margin="0,12,0,5"/>
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom">
              <TextBlock Text="1.2k" FontSize="36" FontWeight="Bold" Foreground="#1A202C"/>
              <TextBlock Text="↑ 12%" FontSize="13" FontWeight="Bold" Foreground="#059669" VerticalAlignment="Bottom" Margin="0,0,0,6"/>
            </StackPanel>
          </StackPanel>
        </Border>

      </Grid>

      <!-- Hive Grid Section -->
      <Border Background="White" CornerRadius="12" BoxShadow="0 2 10 0 #08000000">
        <Grid RowDefinitions="Auto, *">
          
          <!-- Section Header -->
          <Border Grid.Row="0" BorderBrush="#F0F2F5" BorderThickness="0,0,0,1" Padding="24,20">
            <Grid ColumnDefinitions="*, Auto">
              <TextBlock Grid.Column="0" Text="Disposición del Apiario" FontSize="18" FontWeight="Bold" Foreground="#1A202C" VerticalAlignment="Center"/>
              
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="24" VerticalAlignment="Center">
                <!-- Legend -->
                <StackPanel Orientation="Horizontal" Spacing="16">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <Ellipse Width="8" Height="8" Fill="#059669"/>
                    <TextBlock Text="Sana" FontSize="12" FontWeight="SemiBold" Foreground="#4A5568"/>
                  </StackPanel>
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <Ellipse Width="8" Height="8" Fill="#F59E0B"/>
                    <TextBlock Text="Observación" FontSize="12" FontWeight="SemiBold" Foreground="#4A5568"/>
                  </StackPanel>
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <Ellipse Width="8" Height="8" Fill="#DC2626"/>
                    <TextBlock Text="Alerta" FontSize="12" FontWeight="SemiBold" Foreground="#4A5568"/>
                  </StackPanel>
                </StackPanel>

                <Border BorderBrush="#E2E8F0" BorderThickness="1,0,0,0" Height="20"/>

                <!-- View Toggles -->
                <Border Background="#F3F4F6" CornerRadius="6" Padding="4">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <Border Background="White" CornerRadius="4" Padding="6" BoxShadow="0 1 2 0 #10000000">
                      <PathIcon Data="M3 3h8v8H3zm0 10h8v8H3zM13 3h8v8h-8zm0 10h8v8h-8z" Width="14" Height="14" Foreground="#4A5568"/>
                    </Border>
                    <Border Background="Transparent" CornerRadius="4" Padding="6">
                      <PathIcon Data="M3 13h2v-2H3v2zm0 4h2v-2H3v2zm0-8h2V7H3v2zm4 4h14v-2H7v2zm0 4h14v-2H7v2zM7 7v2h14V7H7z" Width="14" Height="14" Foreground="#A0AEC0"/>
                    </Border>
                  </StackPanel>
                </Border>
              </StackPanel>
            </Grid>
          </Border>

          <!-- Hive Grid Content -->
          <Grid Grid.Row="1" Margin="24">
            
            <ItemsControl ItemsSource="{Binding ColmenasList}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="local:ColmenaItem">
                  <!-- Colmena Card -->
                  <Border Width="85" Height="85" CornerRadius="8" BorderThickness="1" 
                          BorderBrush="{Binding BorderColor}" Background="{Binding BgColor}"
                          Margin="0,0,16,16" Padding="8">
                    <!-- Dotted/Dashed stroke would require a special drawing, using BorderBrush is standard Avalonia -->
                    <Grid>
                      <PathIcon Data="{Binding StatusIconData}" Width="14" Height="14" Foreground="{Binding IconColor}" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                      
                      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="6" Margin="0,10,0,0">
                        <PathIcon Data="M20.5 15.1L12 20 3.5 15.1v-6.2L12 4l8.5 4.9v6.2z M12 6.3L6.5 9.5l5.5 3.2 5.5-3.2L12 6.3z" Width="24" Height="24" Foreground="{Binding LogoColor}"/>
                        <TextBlock Text="{Binding Id}" FontSize="12" FontWeight="SemiBold" Foreground="{Binding TextColor}" HorizontalAlignment="Center"/>
                      </StackPanel>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            
          </Grid>
          
          <!-- Footer -->
          <Border Grid.Row="2" BorderBrush="#F0F2F5" BorderThickness="0,1,0,0" Padding="24,16">
            <Grid ColumnDefinitions="*, Auto">
              <TextBlock Grid.Column="0" Text="Selecciona una colmena para ver detalles" FontSize="12" FontWeight="SemiBold" Foreground="#718096" VerticalAlignment="Center"/>
              <Button Grid.Column="1" Background="Transparent" Foreground="#8B5A2B" Content="Registrar Alimentación Masiva" FontWeight="Bold" FontSize="13" Padding="0"/>
            </Grid>
          </Border>

        </Grid>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
